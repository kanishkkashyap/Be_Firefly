# Copy this file to "keystore.properties" (same folder) and fill in real values.
# keystore.properties is gitignored — never commit it or the .jks file.
#
# Create your release keystore once with:
#   keytool -genkey -v -keystore befirefly-release.jks -keyalg RSA -keysize 2048 -validity 10000 -alias befirefly
# Then BACK IT UP. If you lose this keystore you can never update the app again.

storeFile=../befirefly-release.jks
storePassword=CHANGE_ME
keyAlias=befirefly
keyPassword=CHANGE_ME
